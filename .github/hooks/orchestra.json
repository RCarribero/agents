{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "bash": "scripts/hooks/session-start.sh",
        "powershell": "scripts/hooks/session-start.ps1"
      }
    ],
    "userPromptSubmitted": [
      {
        "bash": "scripts/hooks/user-prompt.sh",
        "powershell": "scripts/hooks/user-prompt.ps1"
      }
    ],
    "preToolUse": [
      {
        "bash": "scripts/hooks/pre-tool.sh",
        "powershell": "scripts/hooks/pre-tool.ps1",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "bash": "scripts/hooks/post-tool.sh",
        "powershell": "scripts/hooks/post-tool.ps1"
      }
    ],
    "subagentStop": [
      {
        "bash": "scripts/hooks/subagent-stop.sh",
        "powershell": "scripts/hooks/subagent-stop.ps1"
      }
    ],
    "agentStop": [
      {
        "bash": "scripts/hooks/agent-stop.sh",
        "powershell": "scripts/hooks/agent-stop.ps1"
      }
    ],
    "sessionEnd": [
      {
        "bash": "scripts/hooks/session-end.sh",
        "powershell": "scripts/hooks/session-end.ps1"
      }
    ],
    "errorOccurred": [
      {
        "bash": "scripts/hooks/error-occurred.sh",
        "powershell": "scripts/hooks/error-occurred.ps1"
      }
    ]
  }
}
