---
import type { SessionSummary } from '../types';

interface Props {
  session: SessionSummary;
  active?: boolean;
}

const { session, active = false } = Astro.props;

function formatDate(timestamp: number | null): string {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleString();
}

function formatDuration(start: number | null, end: number | null): string {
  if (!start || !end) return 'N/A';
  const ms = end - start;
  const seconds = Math.floor(ms / 1000);
  const minutes = Math.floor(seconds / 60);
  const hours = Math.floor(minutes / 60);

  if (hours > 0) return `${hours}h ${minutes % 60}m`;
  if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
  return `${seconds}s`;
}
---

<a
  href={`/sessions/${session.id}`}
  class:list={[
    'block rounded-lg border p-4 transition-all hover:shadow-md',
    active
      ? 'border-blue-300 bg-blue-50'
      : 'border-gray-200 bg-white hover:border-gray-300',
  ]}
>
  <div class="flex items-center justify-between">
    <div class="flex flex-1 flex-col">
      <code class="mb-1 text-xs font-mono text-gray-500">{session.id}</code>
      <div class="flex items-center gap-6 text-sm text-gray-600">
        <span>
          <strong>{session.eventCount}</strong> events
        </span>
        <span>
          Started: {formatDate(session.start)}
        </span>
        <span>
          Duration: {formatDuration(session.start, session.end)}
        </span>
      </div>
    </div>
    <div class="ml-4 text-right">
      {
        session.eventCount > 0 && (
          <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
            {Math.round(session.eventCount / (formatDuration(session.start, session.end) === 'N/A' ? 1 : 1))} evt/s
          </span>
        )
      }
    </div>
  </div>
</a>
