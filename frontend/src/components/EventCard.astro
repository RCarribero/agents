---
import type { StoredEvent } from '../types';

interface Props {
  event: StoredEvent;
}

const { event } = Astro.props;

function formatDate(timestamp: number | null): string {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleString();
}

function truncatePayload(payload: unknown, maxLength: number = 150): string {
  const json = JSON.stringify(payload);
  if (json.length > maxLength) {
    return json.slice(0, maxLength) + '...';
  }
  return json;
}
---

<div class="rounded-lg border border-gray-200 bg-white p-4">
  <div class="mb-2 flex items-center justify-between">
    <span class="inline-block rounded bg-indigo-100 px-2 py-1 font-mono text-xs font-semibold text-indigo-700">
      {event.type}
    </span>
    <span class="text-xs text-gray-500">#{event.id}</span>
  </div>
  <p class="mb-2 text-sm text-gray-800">
    {formatDate(event.timestamp)}
  </p>
  <details class="text-xs">
    <summary class="cursor-pointer font-mono text-gray-600 hover:text-gray-900">
      Show payload
    </summary>
    <pre class="mt-2 overflow-auto rounded bg-gray-900 p-3 text-gray-100"><code>{JSON.stringify(event.payload, null, 2)}</code></pre>
  </details>
</div>
