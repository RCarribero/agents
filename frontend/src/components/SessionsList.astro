---
import type { SessionSummary } from '../types';

interface Props {
  sessions: SessionSummary[];
  activeSessionId?: string;
}

const { sessions, activeSessionId } = Astro.props;

interface SessionGroup {
  key: string;
  name: string;
  path: string | null;
  latestTimestamp: number;
  sessions: SessionSummary[];
}

function getSessionSortTimestamp(session: SessionSummary): number {
  return session.end ?? session.start ?? 0;
}

function formatDate(timestamp: number | null): string {
  if (timestamp === null) {
    return 'N/A';
  }

  return new Date(timestamp).toLocaleString();
}

function getSessionLabel(session: SessionSummary): string {
  return session.title?.trim() ? session.title : session.id;
}

function sortSessionsByDate(items: SessionSummary[]): SessionSummary[] {
  return [...items].sort((left, right) => {
    const timestampDelta = getSessionSortTimestamp(right) - getSessionSortTimestamp(left);
    if (timestampDelta !== 0) {
      return timestampDelta;
    }

    return right.id.localeCompare(left.id);
  });
}

function groupSessionsByProject(items: SessionSummary[]): SessionGroup[] {
  const groups = new Map<string, SessionGroup>();

  for (const session of sortSessionsByDate(items)) {
    const existingGroup = groups.get(session.projectKey);
    if (existingGroup) {
      existingGroup.sessions.push(session);
      existingGroup.latestTimestamp = Math.max(existingGroup.latestTimestamp, getSessionSortTimestamp(session));
      continue;
    }

    groups.set(session.projectKey, {
      key: session.projectKey,
      name: session.projectName,
      path: session.projectPath,
      latestTimestamp: getSessionSortTimestamp(session),
      sessions: [session],
    });
  }

  return [...groups.values()].sort((left, right) => {
    const timestampDelta = right.latestTimestamp - left.latestTimestamp;
    if (timestampDelta !== 0) {
      return timestampDelta;
    }

    return left.name.localeCompare(right.name, 'es', { sensitivity: 'base' });
  });
}

const sessionGroups = groupSessionsByProject(sessions);
---

<div id="sessions-list" class="space-y-3">
  {
    sessionGroups.length === 0 ? (
      <div class="rounded-lg border border-gray-200 bg-white p-8 text-center">
        <p class="text-gray-500">No sessions found. Start Copilot to create one.</p>
      </div>
    ) : (
      sessionGroups.map((group) => (
        <section class="space-y-3" data-project-group={group.key}>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="flex flex-col gap-1 md:flex-row md:items-center md:justify-between">
              <div class="min-w-0">
                <h3 class="truncate text-sm font-semibold uppercase tracking-wide text-slate-700">
                  {group.name}
                </h3>
                <p class="text-xs text-slate-500">
                  {group.sessions.length} sesiones
                  {group.path && ` · ${group.path}`}
                </p>
              </div>
              <p class="text-xs font-medium text-slate-500">
                Última actividad: {formatDate(group.latestTimestamp || null)}
              </p>
            </div>
          </div>

          {group.sessions.map((session) => (
            <article
              class:list={[
                'rounded-lg border p-4 transition-all hover:shadow-md',
                activeSessionId === session.id
                  ? 'border-blue-300 bg-blue-50'
                  : 'border-gray-200 bg-white hover:border-gray-300',
              ]}
            >
              <div class="flex items-center justify-between">
                <a href={`/sessions/${session.id}`} class="min-w-0 flex-1">
                  <div class="flex flex-col">
                    <span class="mb-1 truncate text-sm font-semibold text-gray-900">
                      {getSessionLabel(session)}
                    </span>
                    {getSessionLabel(session) !== session.id && (
                      <code class="mb-1 text-xs font-mono text-gray-500">{session.id}</code>
                    )}
                    <div class="flex items-center gap-6 text-sm text-gray-600">
                      <span>
                        <strong>{session.eventCount}</strong> events
                      </span>
                      <span>
                        {formatDate(session.start)}
                      </span>
                    </div>
                  </div>
                </a>
                <div class="ml-4 flex items-center gap-2 text-right">
                  {session.eventCount > 0 && (
                    <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
                      Active
                    </span>
                  )}
                  <button
                    type="button"
                    data-delete-session={session.id}
                    class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-700 transition-colors hover:bg-red-100"
                  >
                    Borrar
                  </button>
                </div>
              </div>
            </article>
          ))}
        </section>
      ))
    )
  }
</div>

<script define:vars={{ activeSessionId }}>
  const htmlEscapeMap = {
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;',
  };

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, (character) => htmlEscapeMap[character] ?? character);
  }

  function formatSessionDate(timestamp) {
    return timestamp == null ? 'N/A' : new Date(timestamp).toLocaleString();
  }

  function getSessionSortTimestamp(session) {
    return session.end ?? session.start ?? 0;
  }

  function getSessionLabel(session) {
    return typeof session.title === 'string' && session.title.trim() ? session.title.trim() : session.id;
  }

  function sortSessionsByDate(sessions) {
    return [...sessions].sort((left, right) => {
      const timestampDelta = getSessionSortTimestamp(right) - getSessionSortTimestamp(left);
      if (timestampDelta !== 0) {
        return timestampDelta;
      }

      return String(right.id).localeCompare(String(left.id));
    });
  }

  function groupSessionsByProject(sessions) {
    const groups = new Map();

    for (const session of sortSessionsByDate(sessions)) {
      const key = session.projectKey ?? 'unknown';
      const existingGroup = groups.get(key);

      if (existingGroup) {
        existingGroup.sessions.push(session);
        existingGroup.latestTimestamp = Math.max(existingGroup.latestTimestamp, getSessionSortTimestamp(session));
        continue;
      }

      groups.set(key, {
        key,
        name: session.projectName ?? 'Sin proyecto detectado',
        path: session.projectPath ?? null,
        latestTimestamp: getSessionSortTimestamp(session),
        sessions: [session],
      });
    }

    return [...groups.values()].sort((left, right) => {
      const timestampDelta = right.latestTimestamp - left.latestTimestamp;
      if (timestampDelta !== 0) {
        return timestampDelta;
      }

      return left.name.localeCompare(right.name, 'es', { sensitivity: 'base' });
    });
  }

  function renderSession(session) {
    const isActive = session.id === activeSessionId;
    const baseClass = isActive
      ? 'rounded-lg border p-4 transition-all hover:shadow-md border-blue-300 bg-blue-50'
      : 'rounded-lg border p-4 transition-all hover:shadow-md border-gray-200 bg-white hover:border-gray-300';
    const label = getSessionLabel(session);
    const sessionIdMarkup =
      label !== session.id
        ? `<code class="mb-1 text-xs font-mono text-gray-500">${escapeHtml(session.id)}</code>`
        : '';

    return `
      <article class="${baseClass}">
        <div class="flex items-center justify-between">
          <a href="/sessions/${session.id}" class="min-w-0 flex-1">
            <div class="flex flex-col">
              <span class="mb-1 truncate text-sm font-semibold text-gray-900">${escapeHtml(label)}</span>
              ${sessionIdMarkup}
              <div class="flex items-center gap-6 text-sm text-gray-600">
                <span><strong>${session.eventCount}</strong> events</span>
                <span>${formatSessionDate(session.start)}</span>
              </div>
            </div>
          </a>
          <div class="ml-4 flex items-center gap-2 text-right">
            ${
              session.eventCount > 0
                ? '<span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">Active</span>'
                : ''
            }
            <button
              type="button"
              data-delete-session="${session.id}"
              class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-700 transition-colors hover:bg-red-100"
            >
              Borrar
            </button>
          </div>
        </div>
      </article>
    `;
  }

  function renderGroup(group) {
    const groupPathMarkup = group.path ? ` · ${escapeHtml(group.path)}` : '';
    const sessionsMarkup = group.sessions.map(renderSession).join('');

    return `
      <section class="space-y-3" data-project-group="${escapeHtml(group.key)}">
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
          <div class="flex flex-col gap-1 md:flex-row md:items-center md:justify-between">
            <div class="min-w-0">
              <h3 class="truncate text-sm font-semibold uppercase tracking-wide text-slate-700">${escapeHtml(group.name)}</h3>
              <p class="text-xs text-slate-500">${group.sessions.length} sesiones${groupPathMarkup}</p>
            </div>
            <p class="text-xs font-medium text-slate-500">Última actividad: ${formatSessionDate(group.latestTimestamp || null)}</p>
          </div>
        </div>
        ${sessionsMarkup}
      </section>
    `;
  }

  function renderSessionsContent(sessions) {
    const groups = groupSessionsByProject(sessions);
    if (!groups.length) {
      return '<div class="rounded-lg border border-gray-200 bg-white p-8 text-center"><p class="text-gray-500">No sessions found. Start Copilot to create one.</p></div>';
    }

    return groups.map(renderGroup).join('');
  }

  // Auto-refresh sessions every 5 seconds
  async function refreshSessions() {
    try {
      const res = await fetch('http://127.0.0.1:3010/sessions');
      if (!res.ok) throw new Error('Failed to fetch');
      const sessions = await res.json();

      const container = document.getElementById('sessions-list');
      if (!container) return;

      container.innerHTML = renderSessionsContent(sessions);
    } catch (error) {
      console.error('[observer] Failed to refresh sessions:', error);
    }
  }

  async function deleteSession(sessionId, button) {
    if (button instanceof HTMLButtonElement) {
      button.disabled = true;
      button.textContent = 'Borrando...';
      button.classList.add('opacity-60', 'cursor-not-allowed');
    }

    try {
      const res = await fetch(`http://127.0.0.1:3010/sessions/${sessionId}`, {
        method: 'DELETE',
      });

      if (!res.ok) {
        throw new Error('Failed to delete session');
      }

      await refreshSessions();
    } catch (error) {
      if (button instanceof HTMLButtonElement) {
        button.disabled = false;
        button.textContent = 'Borrar';
        button.classList.remove('opacity-60', 'cursor-not-allowed');
      }

      window.alert('No se pudo borrar la sesión. Revisa que el backend siga activo.');
      console.error('[observer] Failed to delete session:', error);
    }
  }

  const container = document.getElementById('sessions-list');
  container?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }

    const deleteButton = target.closest('[data-delete-session]');
    if (!(deleteButton instanceof HTMLButtonElement)) {
      return;
    }

    event.preventDefault();
    event.stopPropagation();
    const sessionId = deleteButton.dataset.deleteSession;
    if (sessionId) {
      void deleteSession(sessionId, deleteButton);
    }
  });

  setInterval(refreshSessions, 5000);
</script>
