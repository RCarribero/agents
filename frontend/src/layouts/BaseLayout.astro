---
interface Props {
  title?: string;
}

const { title = "Copilot Observer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50">
    <header class="border-b border-gray-200 bg-white shadow-sm">
      <div class="mx-auto max-w-7xl px-4 py-4">
        <h1 class="text-2xl font-bold text-gray-900">{title}</h1>
      </div>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-12 border-t border-gray-200 bg-white py-4 text-center text-sm text-gray-500">
      <p>Copilot Session Observer • Backend on http://127.0.0.1:3010</p>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>
