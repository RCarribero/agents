---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgentsTree from '../../components/AgentsTree.astro';
import EventCard from '../../components/EventCard.astro';
import type { SessionAgentSummary, StoredEvent, SessionSummary } from '../../types';

interface Params {
  id: string;
}

export async function getStaticPaths() {
  try {
    const res = await fetch('http://127.0.0.1:3010/sessions');
    if (!res.ok) return [];
    const sessions: SessionSummary[] = await res.json();
    return sessions.map((session) => ({
      params: { id: session.id },
    }));
  } catch {
    return [];
  }
}

const { id } = Astro.params as Params;

let session: SessionSummary | null = null;
let events: StoredEvent[] = [];
let agents: SessionAgentSummary[] = [];
let error: string | null = null;

try {
  const sessRes = await fetch(`http://127.0.0.1:3010/sessions`);
  if (sessRes.ok) {
    const sessions: SessionSummary[] = await sessRes.json();
    session = sessions.find((s) => s.id === id) || null;
  }

  const eventsRes = await fetch(`http://127.0.0.1:3010/sessions/${id}/events`);
  if (eventsRes.ok) {
    events = await eventsRes.json();
  } else {
    error = 'Failed to fetch events';
  }

  const agentsRes = await fetch(`http://127.0.0.1:3010/sessions/${id}/agents`);
  if (agentsRes.ok) {
    agents = await agentsRes.json();
  }
} catch (err) {
  error = 'Failed to connect to backend';
}

function formatDate(timestamp: number | null): string {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleString();
}

// Group events by type
const eventsByType = new Map<string, StoredEvent[]>();
events.forEach((event) => {
  const type = event.type;
  if (!eventsByType.has(type)) {
    eventsByType.set(type, []);
  }
  eventsByType.get(type)!.push(event);
});

---

<BaseLayout title={`Session ${id} - Copilot Observer`}>
  <div class="space-y-6">
    <div class="flex items-start justify-between">
      <div>
        <a href="/" class="text-blue-600 hover:text-blue-700">← Back to Sessions</a>
        <h2 class="mt-2 text-2xl font-bold text-gray-900">Session Details</h2>
      </div>
      {session && (
        <div class="flex items-center gap-2">
          <button
            id="btn-toggle-agents"
            type="button"
            class="rounded-lg border border-sky-200 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition-colors hover:bg-sky-100"
          >
            Ver red de agentes
          </button>
          <button
            id="btn-delete-session"
            type="button"
            class="rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100"
          >
            Borrar sesión
          </button>
        </div>
      )}
    </div>

    {
      error ? (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
          <p class="text-sm text-red-800">{error}</p>
        </div>
      ) : session ? (
        <div class="space-y-6">
          <div class="grid gap-4 md:grid-cols-3">
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-xs uppercase text-gray-500">Session ID</p>
              <code class="mt-1 block font-mono text-xs text-gray-700">{session.id}</code>
            </div>
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-xs uppercase text-gray-500">Started</p>
              <p class="mt-1 text-sm text-gray-900">{formatDate(session.start)}</p>
            </div>
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-xs uppercase text-gray-500">Total Events</p>
              <p class="mt-1 text-2xl font-bold text-gray-900">{session.eventCount}</p>
            </div>
          </div>

          <AgentsTree sessionId={id} agents={agents} />

          <div>
            <h3 class="mb-4 text-lg font-semibold text-gray-900">
              Event Types <span class="text-gray-500">({eventsByType.size})</span>
            </h3>
            <div class="space-y-2">
              {Array.from(eventsByType.entries()).map(([type, typeEvents]) => (
                <div class="rounded-lg border border-gray-200 bg-white p-3">
                  <details class="cursor-pointer">
                    <summary class="flex items-center justify-between font-mono text-sm font-semibold text-gray-900">
                      <span>{type}</span>
                      <span class="rounded-full bg-gray-100 px-2 py-1 text-xs font-normal text-gray-600">
                        {typeEvents.length}
                      </span>
                    </summary>
                    <div class="mt-4 space-y-2">
                      {typeEvents.slice(0, 5).map((event) => (
                        <EventCard event={event} />
                      ))}
                      {typeEvents.length > 5 && (
                        <p class="text-xs text-gray-500">
                          ... and {typeEvents.length - 5} more events
                        </p>
                      )}
                    </div>
                  </details>
                </div>
              ))}
            </div>
          </div>

          {events.length > 0 && (
            <div>
              <h3 class="mb-4 text-lg font-semibold text-gray-900">All Events</h3>
              <div class="space-y-3">
                {events.map((event) => (
                  <EventCard event={event} />
                ))}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="rounded-lg border border-gray-200 bg-white p-8 text-center">
          <p class="text-gray-500">Session not found</p>
        </div>
      )
    }
  </div>
</BaseLayout>

<script define:vars={{ sessionId: id }}>
  const toggleAgentsButton = document.getElementById('btn-toggle-agents');
  const deleteSessionButton = document.getElementById('btn-delete-session');
  const agentsPanel = document.getElementById('agents-panel');

  toggleAgentsButton?.addEventListener('click', () => {
    if (!agentsPanel) {
      return;
    }

    const isHidden = agentsPanel.classList.toggle('hidden');
    toggleAgentsButton.textContent = isHidden ? 'Ver red de agentes' : 'Ocultar red';
  });

  deleteSessionButton?.addEventListener('click', async () => {
    if (deleteSessionButton instanceof HTMLButtonElement) {
      deleteSessionButton.disabled = true;
      deleteSessionButton.textContent = 'Borrando...';
      deleteSessionButton.classList.add('opacity-60', 'cursor-not-allowed');
    }

    try {
      const res = await fetch(`http://127.0.0.1:3010/sessions/${sessionId}`, {
        method: 'DELETE',
      });

      if (!res.ok) {
        throw new Error('Failed to delete session');
      }

      window.location.href = '/';
    } catch (error) {
      if (deleteSessionButton instanceof HTMLButtonElement) {
        deleteSessionButton.disabled = false;
        deleteSessionButton.textContent = 'Borrar sesión';
        deleteSessionButton.classList.remove('opacity-60', 'cursor-not-allowed');
      }

      window.alert('No se pudo borrar la sesión. Revisa que el backend siga activo.');
      console.error('[observer] Failed to delete session:', error);
    }
  });
</script>
