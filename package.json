{
  "name": "copilot-session-observer",
  "private": true,
  "version": "0.1.0",
  "description": "Local backend for exploring and serving Copilot session events",
  "scripts": {
    "recon": "node recon.mjs",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/scanSessions.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
