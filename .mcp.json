{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/servers/main/schema/mcp.json",
  "version": "1.0",
  "description": "MCP servers para el sistema multi-agente v3",
  "servers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ],
      "description": "Acceso al sistema de archivos del workspace. Usado por researcher, auditor y backend para leer archivos sin context.files manual.",
      "tools": [
        "read_file",
        "read_multiple_files",
        "write_file",
        "create_directory",
        "list_directory",
        "move_file",
        "search_files",
        "get_file_info"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      },
      "description": "Integración con GitHub. Usado por devops para PRs, commits y revisión de código automatizada.",
      "tools": [
        "create_or_update_file",
        "search_repositories",
        "create_repository",
        "get_file_contents",
        "push_files",
        "create_issue",
        "create_pull_request",
        "fork_repository",
        "create_branch",
        "list_commits",
        "list_issues",
        "update_issue",
        "add_issue_comment",
        "search_code",
        "search_issues",
        "get_pull_request",
        "list_pull_requests"
      ]
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${env:SUPABASE_DB_URL}"
      ],
      "description": "Acceso a Supabase/Postgres. Usado por dbmanager, backend y RAG para queries directas y migraciones.",
      "tools": [
        "query",
        "list_tables",
        "describe_table",
        "create_table",
        "insert_rows",
        "update_rows",
        "delete_rows"
      ]
    },
    "agents-api": {
      "type": "http",
      "url": "${env:AGENTS_API_URL:-http://localhost:8000}",
      "description": "API interna del sistema de agentes. Expone tools de búsqueda, health checks y RAG embedding.",
      "headers": {
        "Authorization": "Bearer ${env:AGENTS_API_KEY}"
      },
      "tools": [
        "health_check",
        "search_products",
        "embed_document",
        "retrieve_context",
        "log_agent_event"
      ]
    }
  },
  "routing": {
    "researcher": ["filesystem", "postgres", "agents-api"],
    "auditor": ["filesystem", "agents-api"],
    "backend": ["filesystem", "postgres"],
    "dbmanager": ["postgres", "filesystem"],
    "devops": ["github"],
    "skill_installer": ["filesystem"],
    "orchestrator": ["agents-api"]
  }
}
