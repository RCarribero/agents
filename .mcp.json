{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/servers/main/schema/mcp.json",
  "version": "1.0",
  "description": "MCP servers para el sistema multi-agente v3",
  "servers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ],
      "description": "Acceso al sistema de archivos del workspace. Usado por agentes de lectura e implementación para consultar archivos sin depender solo de context.files.",
      "tools": [
        "read_file",
        "read_multiple_files",
        "write_file",
        "create_directory",
        "list_directory",
        "move_file",
        "search_files",
        "get_file_info"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      },
      "description": "Integración con GitHub para PRs, issues y operaciones remotas cuando el ciclo lo requiere.",
      "tools": [
        "create_or_update_file",
        "search_repositories",
        "create_repository",
        "get_file_contents",
        "push_files",
        "create_issue",
        "create_pull_request",
        "fork_repository",
        "create_branch",
        "list_commits",
        "list_issues",
        "update_issue",
        "add_issue_comment",
        "search_code",
        "search_issues",
        "get_pull_request",
        "list_pull_requests"
      ]
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${env:POSTGRES_DB_URL}"
      ],
      "description": "Acceso opcional a Postgres para tareas de datos en proyectos activos que requieran queries directas o migraciones.",
      "tools": [
        "query",
        "list_tables",
        "describe_table",
        "create_table",
        "insert_rows",
        "update_rows",
        "delete_rows"
      ]
    }
  },
  "routing": {
    "orchestrator": ["filesystem"],
    "researcher": ["filesystem"],
    "auditor": ["filesystem"],
    "backend": ["filesystem", "postgres"],
    "dbmanager": ["postgres", "filesystem"],
    "devops": ["github"],
    "skill_installer": ["filesystem"]
  }
}
